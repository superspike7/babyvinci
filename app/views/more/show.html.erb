<% content_for :title, "More | BabyVinci" %>

<section class="space-y-6 pb-28">
  <header class="space-y-4 border-b border-vinci-border/80 pb-5">
    <div class="flex items-start justify-between gap-4">
      <div class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-vinci-label">Shared log</p>
        <h1 class="text-3xl font-semibold tracking-tight text-vinci-ink">More</h1>
      </div>

      <span class="shrink-0 rounded-full bg-vinci-accent-tint px-3 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-vinci-accent">
        <%= baby_age_label(current_baby) %>
      </span>
    </div>

    <p class="max-w-[19rem] text-base leading-7 text-vinci-text">Baby profile, shared access, and the small things you might need next.</p>
  </header>

  <%= render "shared/primary_nav", current: :more %>

  <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Baby profile</p>

    <div class="mt-4 flex items-start justify-between gap-4">
      <div class="space-y-2">
        <p class="text-xl font-semibold tracking-tight text-vinci-ink"><%= current_baby.first_name %></p>
        <p class="text-sm leading-6 text-vinci-text"><%= baby_age_in_words(current_baby) %></p>
      </div>

      <span class="shrink-0 rounded-full bg-vinci-accent-tint px-3 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-vinci-accent">
        <%= baby_age_label(current_baby) %>
      </span>
    </div>
  </section>

  <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Doctor visit</p>
    <p class="mt-2 text-sm leading-6 text-vinci-text">Generate a printable summary of recent history for clinic visits.</p>
    <div class="mt-4">
      <%= link_to doctor_summary_path, class: "inline-flex min-h-11 items-center justify-center rounded-full bg-vinci-accent px-5 text-sm font-semibold text-white transition-colors hover:bg-vinci-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/25" do %>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="mr-2 size-4">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10 9 9 9 8 9"/>
        </svg>
        View summary
      <% end %>
    </div>
  </section>

  <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Recent concerns</p>
    <p class="mt-2 text-sm leading-6 text-vinci-text">Safety checks you have completed.</p>
    <div class="mt-4">
      <%= link_to concerns_path, class: "inline-flex min-h-11 items-center justify-center rounded-full border border-vinci-border bg-vinci-surface px-5 text-sm font-semibold text-vinci-accent transition hover:bg-vinci-base focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/15" do %>
        <svg viewBox="0 0 24 24" fill="currentColor" class="mr-2 size-4 text-vinci-accent">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
        </svg>
        View concerns
      <% end %>
    </div>
  </section>

  <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Shared access</p>

    <div class="mt-4 space-y-4">
      <% if @active_invite %>
        <div class="rounded-[20px] border border-vinci-border bg-vinci-surface px-4 py-4">
          <p class="text-sm font-medium text-vinci-ink">Invite ready for <%= @active_invite.email %></p>
          <p class="mt-1 text-sm leading-6 text-vinci-text">Share the current invite link until it is accepted or expires.</p>
          <div class="mt-4">
            <%= secondary_nav_link_to("Open invite details", baby_invite_path(@active_invite)) %>
          </div>
        </div>
      <% elsif current_baby.sharing_limit_reached? %>
        <div class="rounded-[20px] border border-vinci-border bg-vinci-surface px-4 py-4">
          <p class="text-sm font-medium text-vinci-ink">Shared access is full.</p>
          <p class="mt-1 text-sm leading-6 text-vinci-text">This baby log already has 3 people.</p>
        </div>
      <% else %>
        <div class="rounded-[20px] border border-vinci-border bg-vinci-surface px-4 py-4">
          <p class="text-sm font-medium text-vinci-ink">Invite another family member when you are ready.</p>
          <p class="mt-1 text-sm leading-6 text-vinci-text">They will see the same baby timeline and can log events too.</p>
          <div class="mt-4">
            <%= secondary_nav_link_to("Invite family member", new_baby_invite_path) %>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Calendar sync</p>

    <div class="mt-4 space-y-4">
      <% if current_user.google_calendar_connected? %>
        <div class="rounded-[20px] border border-vinci-border bg-vinci-surface px-4 py-4">
          <p class="text-sm font-medium text-vinci-ink">Google Calendar connected</p>
          <% if current_user.google_calendar_email.present? %>
            <p class="mt-1 text-sm leading-6 text-vinci-text"><%= current_user.google_calendar_email %></p>
          <% end %>
          <p class="mt-1 text-sm leading-6 text-vinci-text">Your next-feed reminders will appear in your Google Calendar.</p>
          <%= button_to "Disconnect", google_calendar_connection_path, method: :delete, class: "mt-4 inline-flex min-h-11 items-center text-sm font-semibold text-vinci-accent underline decoration-vinci-accent/60 decoration-2 underline-offset-4 transition-colors hover:text-vinci-ink hover:decoration-vinci-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/25" %>
        </div>
      <% else %>
        <div class="rounded-[20px] border border-vinci-border bg-vinci-surface px-4 py-4">
          <p class="text-sm font-medium text-vinci-ink">Connect your Google Calendar</p>
          <p class="mt-1 text-sm leading-6 text-vinci-text">Get reminders on your phone through your existing calendar.</p>
          <div class="mt-4">
            <%= link_to "Connect Google Calendar", new_google_calendar_connection_path, class: "inline-flex min-h-11 items-center justify-center rounded-full bg-vinci-accent px-5 text-sm font-semibold text-white transition-colors hover:bg-vinci-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/25" %>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Account</p>
    <p class="mt-3 text-sm leading-6 text-vinci-text">Signed in as <span class="font-medium text-vinci-ink"><%= current_user.name %></span>.</p>
    <%= button_to "Sign out", session_path, method: :delete, class: "mt-4 inline-flex min-h-11 items-center text-sm font-semibold text-vinci-accent underline decoration-vinci-accent/60 decoration-2 underline-offset-4 transition-colors hover:text-vinci-ink hover:decoration-vinci-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/25" %>
  </section>

  <%= render "shared/sticky_action_bar" %>
</section>
