<div data-controller="drawer" class="h-full w-full flex flex-col relative overflow-hidden">
  
  <!-- Top 60%: State / Timeline -->
  <div class="flex-1 px-6 pt-16 flex flex-col justify-center items-center bg-blue-950/20">
    <!-- Pulsing glow effect -->
    <div class="relative w-48 h-48 mb-8 flex items-center justify-center">
      <div class="absolute inset-0 bg-blue-500/20 rounded-full animate-[ping_3s_ease-in-out_infinite]"></div>
      <div class="absolute inset-4 bg-blue-500/30 rounded-full animate-[ping_3s_ease-in-out_infinite_0.5s]"></div>
      <div class="relative z-10 text-7xl bg-neutral-900 rounded-full w-32 h-32 flex items-center justify-center border-4 border-blue-500/50 shadow-[0_0_40px_rgba(59,130,246,0.3)]">
        💤
      </div>
    </div>
    
    <h1 class="text-4xl font-bold text-white mb-2 tracking-tight">Sleeping</h1>
    <p class="text-blue-300 text-2xl font-light">for 2h 15m</p>
    
    <!-- Mini recent history -->
    <div class="mt-auto mb-6 w-full flex justify-between px-4 py-3 bg-neutral-900/50 rounded-2xl border border-neutral-800">
      <div class="flex flex-col items-center">
        <span class="text-neutral-500 text-xs uppercase font-bold tracking-wider">Last Feed</span>
        <span class="text-neutral-300">🍼 3h ago</span>
      </div>
      <div class="w-px bg-neutral-800"></div>
      <div class="flex flex-col items-center">
        <span class="text-neutral-500 text-xs uppercase font-bold tracking-wider">Last Diaper</span>
        <span class="text-neutral-300">🧻 3.5h ago</span>
      </div>
    </div>
  </div>

  <!-- Bottom 40%: The Anticipated Action -->
  <div class="h-[40%] bg-neutral-950 p-4 flex flex-col gap-4 relative z-10 pb-8">
    <button data-action="click->drawer#logAndClose" class="flex-1 rounded-[2.5rem] bg-blue-600 active:bg-blue-700 transition-colors shadow-[0_10px_30px_rgba(37,99,235,0.4)] flex flex-col items-center justify-center gap-2 border border-blue-400">
      <span class="text-white font-black text-4xl tracking-widest uppercase">WAKE UP</span>
    </button>
    
    <button data-action="click->drawer#open" data-type="feed" class="h-16 rounded-full bg-neutral-900 border border-neutral-800 text-neutral-400 font-medium active:bg-neutral-800 transition-colors">
      Log other event...
    </button>
  </div>

  <!-- OVERLAY -->
  <div data-drawer-target="overlay" data-action="click->drawer#close" class="absolute inset-0 bg-black/80 backdrop-blur-md z-40 hidden opacity-0 transition-opacity duration-300"></div>

  <!-- OTHER EVENTS DRAWER -->
  <div data-drawer-target="feedDrawer" class="absolute bottom-0 left-0 w-full h-[70%] bg-neutral-900 rounded-t-3xl border-t border-neutral-800 z-50 transform translate-y-full transition-transform duration-300 shadow-2xl flex flex-col">
    <!-- Note: using feedDrawer target just to reuse the same controller logic simply -->
    <div class="w-full flex justify-center pt-3 pb-5" data-action="click->drawer#close">
      <div class="w-12 h-1.5 bg-neutral-700 rounded-full"></div>
    </div>
    
    <div class="px-6 flex-1 flex flex-col gap-4 pb-8">
      <button data-action="click->drawer#logAndClose" class="w-full py-6 rounded-2xl bg-pink-950/40 border border-pink-900/50 text-pink-300 text-2xl font-bold flex items-center justify-center gap-4 active:bg-pink-900/60">
        <span class="text-3xl">🍼</span> Log Feed
      </button>
      <button data-action="click->drawer#logAndClose" class="w-full py-6 rounded-2xl bg-yellow-950/40 border border-yellow-900/50 text-yellow-500 text-2xl font-bold flex items-center justify-center gap-4 active:bg-yellow-900/60">
        <span class="text-3xl">🧻</span> Log Diaper
      </button>
      <button data-action="click->drawer#logAndClose" class="w-full py-6 rounded-2xl bg-neutral-800 border border-neutral-700 text-neutral-300 text-xl font-bold flex items-center justify-center gap-4 active:bg-neutral-700">
        <span class="text-2xl">💊</span> Meds / Temp
      </button>
    </div>
  </div>
</div>