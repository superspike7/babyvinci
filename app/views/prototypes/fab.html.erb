<div class="container">
  <div class="mb-8">
    <h1 class="text-xl font-light mb-2">Quick Actions for Vinci</h1>
    <p class="text-secondary text-sm">Tap the + button to log an activity in seconds</p>
  </div>
  
  <div class="card mb-6">
    <h3 class="font-medium mb-2">✨ Designed for one-handed use</h3>
    <p class="text-secondary text-sm">Perfect for holding Vinci while logging activities.</p>
  </div>
  
  <div class="card">
    <h3 class="font-medium mb-3">Try it yourself!</h3>
    <p class="text-secondary text-sm mb-4">This FAB button is in your thumb's natural reach zone</p>
    <button class="btn btn-primary">🍼 Demo: Log Vinci's feeding</button>
  </div>
</div>

<div class="fab-container">
  <button class="fab" style="
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-primary-light));
    border: none;
    color: white;
    font-size: 28px;
    cursor: pointer;
    box-shadow: 0 4px 12px var(--shadow);
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 1000;
  ">+</button>
</div>
