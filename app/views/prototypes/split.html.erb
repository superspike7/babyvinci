<div class="container">
  <div class="mb-8">
    <h1 class="text-xl font-light mb-2">Split View for Vinci</h1>
    <p class="text-secondary text-sm">Optimized for tablets and landscape orientation</p>
  </div>
  
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div>
      <h2 class="text-lg font-medium mb-4">Timeline (Left)</h2>
      <div class="space-y-4">
        <div class="timeline-item flex items-start p-4 mb-4">
          <div class="timeline-icon text-2xl mr-4 w-12 text-center" style="color: var(--accent-secondary);">🍼</div>
          <div class="timeline-content flex-1">
            <div class="timeline-title font-medium mb-1">Vinci's feeding • 25 min</div>
            <div class="timeline-meta text-sm text-secondary">30m ago</div>
          </div>
        </div>
        <div class="timeline-item flex items-start p-4 mb-4">
          <div class="timeline-icon text-2xl mr-4 w-12 text-center" style="color: var(--accent-primary);">💩</div>
          <div class="timeline-content flex-1">
            <div class="timeline-title font-medium mb-1">Vinci's diaper change</div>
            <div class="timeline-meta text-sm text-secondary">1h ago</div>
          </div>
        </div>
      </div>
    </div>
    
    <div>
      <h2 class="text-lg font-medium mb-4">Quick Actions (Right)</h2>
      <div class="card mb-6">
        <div class="grid grid-cols-1 gap-4">
          <button class="btn btn-primary btn-large">🍼 Log Vinci's feeding</button>
          <button class="btn btn-primary btn-large">💩 Log Vinci's diaper</button>
          <button class="btn btn-primary btn-large">😴 Start sleep timer</button>
        </div>
      </div>
    </div>
  </div>
</div>
