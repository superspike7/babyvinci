<section class="space-y-6 pb-28">
  <header class="space-y-3 border-b border-vinci-border/80 pb-5">
    <div>
      <%= secondary_nav_link_to("Back to today", today_path) %>
    </div>

    <div class="space-y-2">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-vinci-label">Shared log</p>
      <h1 class="text-3xl font-semibold tracking-tight text-vinci-ink">Invite parent</h1>
      <p class="text-base leading-7 text-vinci-text">Invite the second parent by email once the shared log is already useful.</p>
    </div>
  </header>

  <%= render "shared/primary_nav", current: :more %>

  <% if @active_invite %>
    <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5 sm:p-6">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Active invite</p>
      <p class="mt-3 text-base text-vinci-ink"><%= @active_invite.email %></p>
      <p class="mt-2 text-sm leading-6 text-vinci-text">Share the same invite until it is accepted or expires.</p>
      <div class="mt-4">
        <%= secondary_nav_link_to("Open invite details", baby_invite_path(@active_invite)) %>
      </div>
    </section>
  <% else %>
    <%= form_with model: @baby_invite, class: "space-y-5" do |form| %>
      <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5 shadow-[0_22px_70px_rgba(17,63,72,0.10)]">
        <div class="space-y-2">
          <%= form.label :email, class: "text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label" %>
          <%= form.email_field :email, required: true, autofocus: true, autocomplete: "email", class: "w-full rounded-2xl border border-vinci-border bg-vinci-surface px-4 py-4 text-base text-vinci-ink outline-none" %>
        </div>
      </section>

      <% if @baby_invite.errors.any? %>
        <section class="rounded-[20px] border border-vinci-urgent/20 bg-red-50 px-4 py-3 text-sm text-vinci-urgent">
          <%= @baby_invite.errors.full_messages.to_sentence %>
        </section>
      <% end %>

      <div class="sticky bottom-0 z-10 -mx-4 border-t border-vinci-border/80 bg-vinci-surface/95 px-4 pt-4 pb-[calc(1rem+env(safe-area-inset-bottom))] backdrop-blur-sm sm:-mx-8 sm:px-8">
        <%= form.submit "Create invite", class: "w-full rounded-full bg-vinci-accent px-4 py-4 text-base font-semibold text-vinci-surface" %>
      </div>
    <% end %>
  <% end %>
</section>
