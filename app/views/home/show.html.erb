<% content_for :title, "Today | BabyVinci" %>

<section class="space-y-6 pb-28">
  <header class="space-y-4 pb-2">
    <div class="flex items-center justify-between">
      <div class="space-y-0.5">
        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-vinci-label/40 leading-none">Shared Log</p>
        <h1 class="text-4xl font-black tracking-tighter text-vinci-ink">Today</h1>
      </div>
      <div class="flex flex-col items-end">
        <div class="rounded-2xl bg-vinci-ink px-4 py-2.5 text-white shadow-lg shadow-vinci-ink/10">
          <p class="text-[10px] font-black uppercase tracking-widest leading-none"><%= baby_age_label(current_baby).upcase %></p>
        </div>
      </div>
    </div>
    <p class="text-base font-medium text-vinci-text/70">
      <span class="font-bold text-vinci-ink"><%= current_baby.first_name %></span> is <%= baby_age_in_words(current_baby) %>.
    </p>
  </header>

  <%= render "shared/primary_nav", current: :today %>

  <section class="space-y-3">
    <p class="text-sm font-bold uppercase tracking-[0.12em] text-vinci-label">Today totals</p>
    <div class="rounded-3xl border border-vinci-border bg-vinci-base p-5 shadow-sm">
      <div class="flex items-center justify-between gap-2">
        <div class="flex-1 text-center border-r border-vinci-border last:border-0">
          <p class="text-2xl font-black tracking-tight text-vinci-ink"><%= @today_feed_count %></p>
          <p class="text-[9px] font-bold uppercase tracking-widest text-vinci-text/60">Feeds</p>
        </div>
        <div class="flex-1 text-center border-r border-vinci-border last:border-0">
          <p class="text-2xl font-black tracking-tight text-vinci-ink"><%= @today_wet_diaper_count %></p>
          <p class="text-[9px] font-bold uppercase tracking-widest text-vinci-text/60">Wet</p>
        </div>
        <div class="flex-1 text-center border-r border-vinci-border last:border-0">
          <p class="text-2xl font-black tracking-tight text-vinci-ink"><%= @today_stool_diaper_count %></p>
          <p class="text-[9px] font-bold uppercase tracking-widest text-vinci-text/60">Stool</p>
        </div>
        <div class="flex-[1.2] text-center">
          <p class="text-2xl font-black tracking-tight text-vinci-ink"><%= today_sleep_total_label(@today_sleep_total_minutes) %></p>
          <p class="text-[9px] font-bold uppercase tracking-widest text-vinci-text/60">Sleep</p>
        </div>
      </div>
    </div>
  </section>

  <div class="space-y-3">
    <% if @active_sleep %>
      <div class="rounded-[28px] border border-vinci-border bg-vinci-accent px-5 py-5 text-vinci-surface shadow-md">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="flex size-10 items-center justify-center rounded-full bg-vinci-surface/20">
              <svg viewBox="0 0 24 24" fill="currentColor" class="size-5"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-widest opacity-70"><%= @today_guidance[:eyebrow] %></p>
              <p class="text-lg font-black tracking-tight" data-controller="sleep-timer" data-sleep-timer-started-at-value="<%= @today_guidance[:sleep_started_at] %>" data-sleep-timer-prefix-value="Sleeping for" data-sleep-timer-include-ago-value="false" data-sleep-timer-target="elapsed">
                <%= @today_guidance[:headline] %>
              </p>
              <p class="mt-1 text-sm font-semibold text-vinci-surface/80"><%= @today_guidance[:support] %></p>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="rounded-[28px] border border-vinci-border/80 bg-vinci-accent-tint p-5 shadow-sm">
      <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <div class="flex size-10 items-center justify-center rounded-full bg-vinci-surface/80 text-vinci-accent shadow-inner">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-5"><path d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-vinci-label">Feed reminder</p>
            <p class="text-xl font-black tracking-tight text-vinci-accent"><%= next_feed_reminder_title(@next_feed_reminder) %></p>
            <% if @next_feed_reminder.persisted? %>
              <p class="text-[11px] font-bold tracking-wide text-vinci-text/75"><%= next_feed_reminder_timing_label(@next_feed_reminder) %></p>
              <% if @next_feed_reminder.calendar_sync_failed_at.present? %>
                <div class="mt-2 space-y-1">
                  <p class="text-[11px] font-semibold text-vinci-urgent">Calendar sync failed. Your reminder is saved in BabyVinci.</p>
                  <p class="text-[11px] text-vinci-text/70">Tap edit to try again.</p>
                </div>
              <% end %>
            <% else %>
              <p class="text-[11px] font-semibold text-vinci-text/75">Add one if a shared nudge would help.</p>
            <% end %>
          </div>
        </div>

        <% if @next_feed_reminder.persisted? %>
          <div class="flex items-center gap-2">
            <details class="group relative">
              <summary class="flex size-10 cursor-pointer list-none items-center justify-center rounded-full bg-vinci-accent text-vinci-base shadow-sm transition active:scale-95">
                <span class="sr-only">Edit reminder</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="M12 20h9M16.5 3.5a2.1 2.1 0 1 1 3 3L7 19l-4 1 1-4 12.5-12.5Z"/></svg>
              </summary>
              <div class="absolute right-0 top-12 z-20 w-64 space-y-4 rounded-[24px] border border-vinci-border/70 bg-vinci-base p-5 shadow-2xl">
                <div>
                  <p class="mb-3 text-[10px] font-bold uppercase tracking-widest text-vinci-label">Reset nudge</p>
                  <% reminder_presets = [[30, "30m"], [60, "1h"], [120, "2h"], [180, "3h"]] %>
                  <div class="grid grid-cols-2 gap-2">
                    <% reminder_presets.each do |minutes, label| %>
                      <%= button_to label, next_feed_reminder_path, method: :patch, params: { preset_minutes: minutes }, form_class: "w-full", class: "w-full flex min-h-10 items-center justify-center rounded-full border border-vinci-border bg-vinci-surface text-xs font-bold text-vinci-accent transition active:scale-95" %>
                    <% end %>
                  </div>
                </div>
                <%= form_with model: @next_feed_reminder, url: next_feed_reminder_path, method: :patch, class: "space-y-3" do |f| %>
                  <%= f.datetime_local_field :target_at, value: next_feed_reminder_input_value(@next_feed_reminder), class: "block w-full rounded-xl border-vinci-border bg-vinci-surface text-sm font-medium focus:ring-vinci-accent/20" %>
                  <div class="grid grid-cols-2 gap-2">
                    <%= link_to next_feed_reminder_path, data: { turbo_method: :delete }, class: "flex h-10 items-center justify-center rounded-full border border-vinci-border bg-vinci-base text-vinci-urgent" do %>
                      <span class="sr-only">Clear reminder</span>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-4"><path d="M3 6h18M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                    <% end %>
                    <%= f.submit "Save", class: "rounded-full bg-vinci-accent text-xs font-bold text-vinci-base" %>
                  </div>
                <% end %>
              </div>
            </details>
          </div>
        <% else %>
          <div class="w-full max-w-[11rem] space-y-3">
            <div>
              <p class="mb-2 text-[10px] font-bold uppercase tracking-widest text-vinci-label">Quick presets</p>
              <div class="flex flex-wrap gap-1.5">
                <% [[30, "30 min"], [60, "1 hour"], [120, "2 hours"], [180, "3 hours"]].each do |minutes, label| %>
                  <%= button_to label, next_feed_reminder_path, method: :post, params: { preset_minutes: minutes }, form_class: "inline-block", class: "flex h-9 min-w-10 items-center justify-center rounded-full bg-vinci-surface px-2 text-[10px] font-black uppercase tracking-widest text-vinci-accent shadow-sm transition active:scale-95" %>
                <% end %>
              </div>
            </div>

            <%= form_with model: @next_feed_reminder, url: next_feed_reminder_path, class: "space-y-2" do |f| %>
              <div class="space-y-1">
                <%= f.label :target_at, "Exact time", class: "text-[10px] font-bold uppercase tracking-widest text-vinci-label" %>
                <%= f.datetime_local_field :target_at, class: "block w-full rounded-xl border-vinci-border bg-vinci-surface text-sm font-medium focus:ring-vinci-accent/20" %>
              </div>
              <%= f.submit "Save", class: "w-full rounded-full bg-vinci-accent px-3 py-2 text-[10px] font-black uppercase tracking-widest text-vinci-base" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-3">
    <div class="rounded-[28px] border border-vinci-border bg-vinci-base p-4 shadow-sm">
      <p class="text-[9px] font-bold uppercase tracking-widest text-vinci-label">Last feed</p>
      <% if @last_feed %>
        <div class="mt-2 space-y-1.5">
          <div class="flex items-baseline justify-between">
            <p class="text-sm font-bold text-vinci-ink">Time</p>
            <p class="text-sm font-black text-vinci-ink"><%= care_event_time(@last_feed) %></p>
          </div>
          <div class="flex items-baseline justify-between">
            <p class="text-[10px] font-bold text-vinci-text/60">Since</p>
            <p class="text-[10px] font-bold text-vinci-text/60"><%= compact_sleep_duration_label(elapsed_minutes_since(@last_feed.started_at)) %></p>
          </div>
          <div class="flex items-baseline justify-between">
            <p class="text-[10px] font-bold text-vinci-text/60">Today</p>
            <p class="text-[10px] font-bold text-vinci-text/60"><%= @today_feed_count %></p>
          </div>
          <p class="mt-1 rounded-lg bg-vinci-accent-tint/30 p-2 text-[10px] font-semibold text-vinci-accent"><%= care_event_detail(@last_feed) %></p>
        </div>
      <% else %>
        <p class="mt-2 text-sm font-medium text-vinci-text/40 italic">No feed yet</p>
      <% end %>
    </div>

    <div class="rounded-[28px] border border-vinci-border bg-vinci-base p-4 shadow-sm">
      <p class="text-[9px] font-bold uppercase tracking-widest text-vinci-label">Last diaper</p>
      <% if @last_diaper %>
        <div class="mt-2 space-y-1.5">
          <div class="flex items-baseline justify-between">
            <p class="text-sm font-bold text-vinci-ink">Time</p>
            <p class="text-sm font-black text-vinci-ink"><%= care_event_time(@last_diaper) %></p>
          </div>
          <div class="flex items-baseline justify-between">
            <p class="text-[10px] font-bold text-vinci-text/60">Since</p>
            <p class="text-[10px] font-bold text-vinci-text/60"><%= compact_sleep_duration_label(elapsed_minutes_since(@last_diaper.started_at)) %></p>
          </div>
          <div class="flex items-baseline justify-between gap-1">
            <p class="text-[10px] font-bold text-vinci-text/60">Today</p>
            <p class="text-[10px] font-bold text-vinci-text/60 truncate"><%= @today_wet_diaper_count %>W · <%= @today_stool_diaper_count %>S</p>
          </div>
          <p class="mt-1 rounded-lg bg-vinci-accent-tint/30 p-2 text-[10px] font-semibold text-vinci-accent"><%= care_event_detail(@last_diaper) %></p>
        </div>
      <% else %>
        <p class="mt-2 text-sm font-medium text-vinci-text/40 italic">No diaper yet</p>
      <% end %>
    </div>

    <% if !@active_sleep %>
      <div class="col-span-2 rounded-[28px] border border-vinci-border bg-vinci-base p-5 shadow-sm">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-vinci-label">Last sleep</p>
            <p class="mt-1 text-lg font-black tracking-tight text-vinci-ink"><%= @last_sleep ? sleep_duration_label(@last_sleep.duration_minutes) : "None yet" %></p>
          </div>
          <div class="flex items-center gap-3">
            <% if @last_sleep %>
              <p class="text-xs font-bold text-vinci-text/50"><%= sleep_detail_label(@last_sleep) %></p>
              <%= link_to "Edit", edit_care_event_path(@last_sleep, return_to: today_path), class: "inline-flex min-h-10 items-center text-xs font-black uppercase tracking-widest text-vinci-accent underline decoration-vinci-accent/60 decoration-2 underline-offset-4 transition-colors hover:text-vinci-ink hover:decoration-vinci-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/25" %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="space-y-3 pt-2">
    <section class="rounded-[28px] border border-vinci-border bg-vinci-base p-5 shadow-sm">
      <details class="group">
        <summary class="flex cursor-pointer list-none items-center justify-between marker:hidden">
          <div class="flex items-center gap-3">
            <div class="flex size-10 items-center justify-center rounded-full bg-vinci-urgent/10 text-vinci-urgent">
              <svg viewBox="0 0 24 24" fill="currentColor" class="size-5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
            </div>
            <div>
              <p class="text-sm font-bold uppercase tracking-wider text-vinci-label">Concerned?</p>
              <p class="text-[11px] font-medium text-vinci-text/60">Guided safety checks</p>
            </div>
          </div>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-vinci-text/30 transition group-open:rotate-180"><path d="m6 9 6 6 6-6"/></svg>
        </summary>
        <div class="mt-5 space-y-3">
          <%= link_to concerns_path, class: "block rounded-2xl border border-vinci-border bg-vinci-surface px-4 py-4 transition active:scale-[0.98]" do %>
            <div class="flex items-center justify-between">
              <div class="space-y-0.5">
                <p class="text-sm font-bold text-vinci-ink">Start screening</p>
                <p class="text-[11px] text-vinci-text/60">Fever, breathing, vomiting...</p>
              </div>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-vinci-text/30"><path d="m9 18 6-6-6-6"/></svg>
            </div>
          <% end %>
        </div>
      </details>
    </section>

    <% if @guidance_notes.any? %>
      <section class="rounded-[28px] border border-vinci-border bg-vinci-base p-5 shadow-sm">
        <details class="group">
          <summary class="flex cursor-pointer list-none items-center justify-between marker:hidden">
            <div class="flex items-center gap-3">
              <div class="flex size-10 items-center justify-center rounded-full bg-vinci-accent-tint/60 text-vinci-accent">
                <svg viewBox="0 0 24 24" fill="currentColor" class="size-5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
              </div>
              <p class="text-sm font-bold uppercase tracking-wider text-vinci-label">At this age</p>
            </div>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-vinci-text/30 transition group-open:rotate-180"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="mt-4 space-y-3 pl-13">
            <% @guidance_notes.each do |note| %>
              <p class="text-sm font-medium leading-relaxed text-vinci-ink"><%= note %></p>
            <% end %>
          </div>
        </details>
      </section>
    <% end %>

    <section class="rounded-[28px] border border-vinci-border bg-vinci-base p-5 shadow-sm">
      <div class="mb-4 flex items-center justify-between gap-4">
        <p class="text-[10px] font-black uppercase tracking-widest text-vinci-label">Recent activity</p>
        <%= link_to "Open timeline", timeline_path, class: "text-[10px] font-black uppercase tracking-widest text-vinci-accent underline underline-offset-4" %>
      </div>

      <% if @recent_care_events.any? %>
        <div class="divide-y divide-vinci-border/50">
          <% @recent_care_events.take(5).each do |event| %>
            <div class="py-3">
              <%= render "timeline/care_event", event: event %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="py-6 text-center text-sm font-medium text-vinci-text/40 italic">Nothing logged yet</p>
      <% end %>
    </section>
  </div>

  <%= render "shared/sticky_action_bar" %>

</section>
