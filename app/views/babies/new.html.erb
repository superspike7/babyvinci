<section class="space-y-6">
  <header class="space-y-4">
    <div class="flex items-start justify-between gap-4">
      <div class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-vinci-label">Baby setup</p>
        <h1 class="text-3xl font-semibold tracking-tight text-vinci-ink">Create your baby's profile</h1>
      </div>

      <span class="shrink-0 rounded-full bg-vinci-accent-tint px-3 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-vinci-accent">
        First step
      </span>
    </div>

    <div class="space-y-2 text-vinci-text">
      <p class="text-base leading-7">Start with one shared baby profile. You can invite the second parent later.</p>
      <p class="text-sm font-medium">Signed in as <%= current_user.name %>.</p>
    </div>
  </header>

  <%= form_with model: @baby, class: "space-y-5", html: { novalidate: true } do |form| %>
    <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5 sm:p-6">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Baby details</p>

      <div class="mt-4 space-y-4">
        <div class="space-y-2">
          <%= form.label :first_name, "Baby's first name", class: "text-sm font-medium text-vinci-ink" %>
          <%= form.text_field :first_name, required: true, autofocus: true, autocomplete: "given-name", class: "w-full rounded-2xl border border-vinci-border bg-vinci-surface px-4 py-4 text-base text-vinci-ink outline-none transition focus:border-vinci-accent focus:ring-2 focus:ring-vinci-accent/10" %>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="space-y-2">
            <%= form.label :birth_date, "Birth date", class: "text-sm font-medium text-vinci-ink" %>
            <%= form.date_field :birth_date, required: true, max: Date.current, value: @baby.birth_at&.to_date, class: "w-full rounded-2xl border border-vinci-border bg-vinci-surface px-4 py-4 text-base text-vinci-ink outline-none transition focus:border-vinci-accent focus:ring-2 focus:ring-vinci-accent/10" %>
          </div>

          <div class="space-y-2">
            <%= form.label :birth_time, class: "text-sm font-medium text-vinci-ink" %>
            <%= form.time_field :birth_time, required: true, value: @baby.birth_at&.strftime("%H:%M"), class: "w-full rounded-2xl border border-vinci-border bg-vinci-surface px-4 py-4 text-base text-vinci-ink outline-none transition focus:border-vinci-accent focus:ring-2 focus:ring-vinci-accent/10" %>
          </div>
        </div>
      </div>
    </section>

    <% if @baby.errors.any? %>
      <section class="rounded-[20px] border border-vinci-urgent/20 bg-red-50 px-4 py-3 text-sm text-vinci-urgent">
        <%= @baby.errors.full_messages.to_sentence %>
      </section>
    <% end %>

    <%= form.submit "Save baby profile", class: "w-full rounded-full bg-vinci-accent px-4 py-4 text-base font-semibold text-vinci-surface transition hover:bg-vinci-ink focus:ring-2 focus:ring-vinci-accent/20 focus:outline-none" %>
  <% end %>
</section>
