<% content_for :title, "#{page_title} | BabyVinci" %>

<section class="space-y-6 pb-28">
  <header class="space-y-4 border-b border-vinci-border/80 pb-5">
    <div>
      <%= secondary_nav_link_to(back_label, back_path) %>
    </div>

    <div class="flex items-start justify-between gap-4">
      <div class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-vinci-label">Shared log</p>
        <h1 class="text-3xl font-semibold tracking-tight text-vinci-ink"><%= page_title %></h1>
      </div>

      <span class="shrink-0 rounded-full bg-vinci-accent-tint px-3 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-vinci-accent">
        <%= chip_label %>
      </span>
    </div>

    <p class="max-w-[19rem] text-base leading-7 text-vinci-text"><%= intro %></p>
  </header>

  <%= render "shared/primary_nav", current: nil %>

  <%= form_with model: care_event, url: form_url, class: "space-y-5", html: { novalidate: true } do |form| %>
    <% if return_to.present? %>
      <%= hidden_field_tag :return_to, return_to %>
    <% end %>

    <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5 sm:p-6">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Required</p>

      <div class="mt-4 space-y-5">
        <div class="space-y-2">
          <%= form.label :started_at, "Time", class: "text-sm font-medium text-vinci-ink" %>
          <%= form.datetime_local_field :started_at, required: true, value: (care_event.started_at || Time.zone.now.change(sec: 0)).strftime("%Y-%m-%dT%H:%M"), class: "w-full rounded-2xl border border-vinci-border bg-vinci-surface px-4 py-4 text-base text-vinci-ink outline-none transition focus:border-vinci-accent focus:ring-2 focus:ring-vinci-accent/10" %>
        </div>

        <fieldset class="space-y-3">
          <legend class="text-sm font-medium text-vinci-ink">Type</legend>
          <div class="grid gap-3">
            <% CareEvent::DIAPER_TYPES.each do |diaper_type| %>
              <% selected = care_event.diaper_type == diaper_type %>
              <label class="flex min-h-12 items-center gap-3 rounded-2xl border px-4 py-4 text-base transition <%= selected ? "border-vinci-accent bg-vinci-accent-tint text-vinci-accent" : "border-vinci-border bg-vinci-surface text-vinci-ink" %>">
                <%= form.radio_button :diaper_type, diaper_type, required: true, checked: selected, class: "h-4 w-4 border-vinci-border text-vinci-accent focus:ring-vinci-accent" %>
                <span><%= diaper_type_label(diaper_type) %></span>
              </label>
            <% end %>
          </div>
        </fieldset>
      </div>
    </section>

    <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5 sm:p-6">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Optional</p>

      <div class="mt-4 space-y-2">
        <%= form.label :color, "Poop color note", class: "text-sm font-medium text-vinci-ink" %>
        <%= form.text_field :color, value: care_event.diaper_color, class: "w-full rounded-2xl border border-vinci-border bg-vinci-surface px-4 py-4 text-base text-vinci-ink outline-none transition focus:border-vinci-accent focus:ring-2 focus:ring-vinci-accent/10" %>
      </div>
    </section>

    <% if care_event.errors.any? %>
      <section class="rounded-[20px] border border-vinci-urgent/20 bg-red-50 px-4 py-3 text-sm text-vinci-urgent">
        <%= care_event.errors.full_messages.to_sentence %>
      </section>
    <% end %>

    <div class="sticky bottom-0 z-10 -mx-4 border-t border-vinci-border/80 bg-vinci-surface/95 px-4 pt-4 pb-[calc(1rem+env(safe-area-inset-bottom))] backdrop-blur-sm sm:-mx-8 sm:px-8">
      <%= form.submit submit_label, class: "w-full rounded-full bg-vinci-accent px-4 py-4 text-base font-semibold text-vinci-surface transition hover:bg-vinci-ink focus:outline-none focus:ring-2 focus:ring-vinci-accent/20" %>
    </div>
  <% end %>

  <% if delete_url.present? %>
    <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5 sm:p-6">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Remove</p>
      <p class="mt-3 max-w-[19rem] text-base leading-7 text-vinci-text">Delete this diaper if it was logged by mistake.</p>

      <%= button_to "Delete diaper", delete_url, method: :delete, params: { return_to: return_to }, data: { turbo_confirm: "Delete this diaper?" }, class: "mt-4 w-full rounded-full border border-vinci-urgent/25 bg-vinci-base px-4 py-4 text-base font-semibold text-vinci-urgent transition hover:border-vinci-urgent hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-vinci-urgent/15" %>
    </section>
  <% end %>
</section>
