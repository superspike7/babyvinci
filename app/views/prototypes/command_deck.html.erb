<div data-controller="drawer" class="h-full w-full flex flex-col relative overflow-hidden">
  
  <!-- Top 65%: Timeline -->
  <div class="flex-1 overflow-y-auto px-4 pt-12 pb-6 flex flex-col gap-6 no-scrollbar">
    <div class="flex items-end justify-between mb-4">
      <div>
        <h1 class="text-3xl font-bold text-white tracking-tight">Today</h1>
        <p class="text-neutral-400">Last fed 2h ago</p>
      </div>
    </div>

    <!-- Timeline Entries -->
    <div class="flex flex-col gap-4">
      <div class="flex gap-4 items-center">
        <div class="w-12 h-12 rounded-full bg-blue-900/30 flex items-center justify-center text-blue-400 text-2xl border border-blue-900/50">💤</div>
        <div class="flex-1 border-b border-neutral-800 pb-4">
          <p class="text-white text-lg font-medium">Woke up</p>
          <p class="text-neutral-400 text-sm">Slept for 1h 45m • 2h ago</p>
        </div>
      </div>
      
      <div class="flex gap-4 items-center">
        <div class="w-12 h-12 rounded-full bg-pink-900/30 flex items-center justify-center text-pink-400 text-2xl border border-pink-900/50">🍼</div>
        <div class="flex-1 border-b border-neutral-800 pb-4">
          <p class="text-white text-lg font-medium">Feed (Left Breast)</p>
          <p class="text-neutral-400 text-sm">25 mins • 4h ago</p>
        </div>
      </div>

      <div class="flex gap-4 items-center">
        <div class="w-12 h-12 rounded-full bg-yellow-900/30 flex items-center justify-center text-yellow-500 text-2xl border border-yellow-900/50">🧻</div>
        <div class="flex-1 border-b border-neutral-800 pb-4">
          <p class="text-white text-lg font-medium">Dirty Diaper</p>
          <p class="text-neutral-400 text-sm">Brown/Normal • 5h ago</p>
        </div>
      </div>
      
      <div class="flex gap-4 items-center opacity-50">
        <div class="w-12 h-12 rounded-full bg-blue-900/30 flex items-center justify-center text-blue-400 text-2xl border border-blue-900/50">💤</div>
        <div class="flex-1 pb-4">
          <p class="text-white text-lg font-medium">Fell Asleep</p>
          <p class="text-neutral-400 text-sm">Crib • 6h ago</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom 35%: Command Deck Buttons -->
  <div class="h-[35%] bg-neutral-900 grid grid-cols-2 grid-rows-2 gap-1 p-1">
    <button data-action="click->drawer#open" data-type="feed" class="col-span-2 rounded-2xl bg-pink-950/40 border border-pink-900/50 flex flex-col items-center justify-center gap-1 active:bg-pink-900/60 transition-colors">
      <span class="text-4xl">🍼</span>
      <span class="text-pink-300 font-bold text-xl tracking-wide">FEED</span>
    </button>
    <button data-action="click->drawer#open" data-type="sleep" class="rounded-2xl bg-blue-950/40 border border-blue-900/50 flex flex-col items-center justify-center gap-1 active:bg-blue-900/60 transition-colors">
      <span class="text-4xl">💤</span>
      <span class="text-blue-300 font-bold tracking-wide">SLEEP</span>
    </button>
    <button data-action="click->drawer#open" data-type="diaper" class="rounded-2xl bg-yellow-950/40 border border-yellow-900/50 flex flex-col items-center justify-center gap-1 active:bg-yellow-900/60 transition-colors">
      <span class="text-4xl">🧻</span>
      <span class="text-yellow-500 font-bold tracking-wide">DIAPER</span>
    </button>
  </div>

  <!-- OVERLAY -->
  <div data-drawer-target="overlay" data-action="click->drawer#close" class="absolute inset-0 bg-black/60 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300"></div>

  <!-- FEED DRAWER -->
  <div data-drawer-target="feedDrawer" class="absolute bottom-0 left-0 w-full h-[60%] bg-neutral-900 rounded-t-3xl border-t border-neutral-800 z-50 transform translate-y-full transition-transform duration-300 shadow-2xl flex flex-col">
    <div class="w-full flex justify-center pt-3 pb-5" data-action="click->drawer#close">
      <div class="w-12 h-1.5 bg-neutral-700 rounded-full"></div>
    </div>
    <div class="px-6 flex-1 flex flex-col gap-4 pb-8">
      <h2 class="text-2xl font-bold text-white mb-2 text-center">Log Feed</h2>
      <button data-action="click->drawer#logAndClose" class="w-full py-6 rounded-2xl bg-pink-900/30 border border-pink-900/50 text-pink-300 text-2xl font-bold relative overflow-hidden active:bg-pink-900/60">
        Left Breast
      </button>
      <button data-action="click->drawer#logAndClose" class="w-full py-6 rounded-2xl bg-pink-900/30 border border-pink-900/50 text-pink-300 text-2xl font-bold relative overflow-hidden active:bg-pink-900/60">
        Right Breast
      </button>
      <div class="grid grid-cols-2 gap-4 mt-2">
        <button data-action="click->drawer#logAndClose" class="w-full py-5 rounded-2xl bg-neutral-800 border border-neutral-700 text-neutral-300 text-xl font-bold relative overflow-hidden active:bg-neutral-700">
          Bottle
        </button>
        <button data-action="click->drawer#logAndClose" class="w-full py-5 rounded-2xl bg-neutral-800 border border-neutral-700 text-neutral-300 text-xl font-bold relative overflow-hidden active:bg-neutral-700">
          Pump
        </button>
      </div>
    </div>
  </div>

  <!-- SLEEP DRAWER -->
  <div data-drawer-target="sleepDrawer" class="absolute bottom-0 left-0 w-full h-[40%] bg-neutral-900 rounded-t-3xl border-t border-neutral-800 z-50 transform translate-y-full transition-transform duration-300 shadow-2xl flex flex-col">
    <div class="w-full flex justify-center pt-3 pb-5" data-action="click->drawer#close">
      <div class="w-12 h-1.5 bg-neutral-700 rounded-full"></div>
    </div>
    <div class="px-6 flex-1 flex flex-col justify-center gap-4 pb-8">
      <button data-action="click->drawer#logAndClose" class="w-full py-8 rounded-3xl bg-blue-900/30 border border-blue-900/50 text-blue-300 text-3xl font-bold relative overflow-hidden active:bg-blue-900/60">
        Start Sleep
      </button>
    </div>
  </div>

  <!-- DIAPER DRAWER -->
  <div data-drawer-target="diaperDrawer" class="absolute bottom-0 left-0 w-full h-[50%] bg-neutral-900 rounded-t-3xl border-t border-neutral-800 z-50 transform translate-y-full transition-transform duration-300 shadow-2xl flex flex-col">
    <div class="w-full flex justify-center pt-3 pb-5" data-action="click->drawer#close">
      <div class="w-12 h-1.5 bg-neutral-700 rounded-full"></div>
    </div>
    <div class="px-6 flex-1 flex flex-col gap-4 pb-8">
      <h2 class="text-2xl font-bold text-white mb-2 text-center">Log Diaper</h2>
      <button data-action="click->drawer#logAndClose" class="w-full py-6 rounded-2xl bg-yellow-900/30 border border-yellow-900/50 text-yellow-500 text-2xl font-bold relative overflow-hidden active:bg-yellow-900/60">
        Wet
      </button>
      <button data-action="click->drawer#logAndClose" class="w-full py-6 rounded-2xl bg-[#5C4033]/40 border border-[#5C4033]/60 text-amber-600 text-2xl font-bold relative overflow-hidden active:bg-[#5C4033]/60">
        Dirty
      </button>
    </div>
  </div>
</div>