<% content_for :title, "Timeline | BabyVinci" %>

<section class="space-y-6 pb-28">
  <header class="space-y-3 border-b border-vinci-border/80 pb-5">
    <div>
      <%= secondary_nav_link_to("Back to today", today_path) %>
    </div>

    <div class="flex items-start justify-between gap-4">
      <div class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-vinci-label">Shared log</p>
        <h1 class="text-3xl font-semibold tracking-tight text-vinci-ink">Timeline</h1>
      </div>

      <span class="shrink-0 rounded-full bg-vinci-accent-tint px-3 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-vinci-accent">
        <%= baby_age_label(current_baby) %>
      </span>
    </div>

    <p class="max-w-[18rem] text-base leading-7 text-vinci-text">
      Shared care events for <span class="font-medium text-vinci-ink"><%= current_baby.first_name %></span>.
    </p>
  </header>

  <%= render "shared/primary_nav", current: :timeline %>

  <% if @timeline_days.any? %>
    <section class="space-y-4">
      <% @timeline_days.each do |date, events| %>
        <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5">
          <div class="flex items-center justify-between gap-4 border-b border-vinci-border/80 pb-4">
            <h2 class="text-lg font-semibold tracking-tight text-vinci-ink"><%= timeline_day_label(date) %></h2>
            <p class="text-sm text-vinci-text"><%= pluralize(events.size, "log") %></p>
          </div>

          <div class="mt-2 divide-y divide-vinci-border/80">
            <% events.each do |event| %>
              <%= render "care_event", event: event %>
            <% end %>
          </div>
        </section>
      <% end %>
    </section>
  <% else %>
    <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5">
      <div class="rounded-[20px] border border-dashed border-vinci-border bg-vinci-surface px-4 py-5">
        <p class="text-base font-medium text-vinci-ink">Nothing logged yet</p>
        <p class="mt-1 text-sm leading-6 text-vinci-text">The shared timeline will appear here once a feed or diaper is logged.</p>
      </div>
    </section>
  <% end %>

  <%= render "shared/sticky_action_bar" %>
</section>
