<% content_for :title, "Today | BabyVinci" %>

<section class="space-y-6">
  <header class="space-y-3 border-b border-vinci-border/80 pb-5">
    <div class="flex items-start justify-between gap-4">
      <div class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-vinci-label">Shared log</p>
        <h1 class="text-3xl font-semibold tracking-tight text-vinci-ink">Today</h1>
      </div>

      <div class="flex flex-col items-end gap-2">
        <span class="shrink-0 rounded-full bg-vinci-accent-tint px-3 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-vinci-accent">
          <%= baby_age_label(current_baby) %>
        </span>

        <%= button_to "Sign out", session_path, method: :delete, class: "text-sm font-medium text-vinci-text" %>
      </div>
    </div>

    <p class="max-w-[18rem] text-base leading-7 text-vinci-text">
      <span class="font-medium text-vinci-ink"><%= current_baby.first_name %></span>
      is <%= baby_age_in_words(current_baby) %>.
    </p>

    <div>
      <%= secondary_nav_link_to("Invite parent", new_baby_invite_path) %>
    </div>
  </header>

  <section class="grid gap-4 sm:grid-cols-2">
    <article class="rounded-[26px] border border-vinci-border bg-vinci-base p-5 sm:p-6">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Last feed</p>
      <p class="mt-3 text-2xl font-semibold tracking-tight text-vinci-ink"><%= @last_feed ? latest_care_event_label(@last_feed) { "feed" } : "No feed yet" %></p>
      <% if @last_feed %>
        <p class="mt-2 text-sm leading-6 text-vinci-text"><%= care_event_detail(@last_feed) %></p>
      <% end %>
    </article>

    <article class="rounded-[26px] border border-vinci-border bg-vinci-base p-5 sm:p-6">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Last diaper</p>
      <p class="mt-3 text-2xl font-semibold tracking-tight text-vinci-ink"><%= @last_diaper ? latest_care_event_label(@last_diaper) { "diaper" } : "No diaper yet" %></p>
      <% if @last_diaper %>
        <p class="mt-2 text-sm leading-6 text-vinci-text"><%= care_event_detail(@last_diaper) %></p>
      <% end %>
    </article>
  </section>

  <section class="rounded-[26px] border border-vinci-border bg-vinci-accent p-6 text-vinci-surface shadow-[0_22px_70px_rgba(17,63,72,0.10)]">
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-vinci-accent-tint">What matters now</p>
    <p class="mt-3 text-lg leading-7">Log the latest feed or diaper.</p>
  </section>

  <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5 sm:p-6">
    <div class="flex items-center justify-between gap-4">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Recent activity</p>
      <%= secondary_nav_link_to("Open timeline", timeline_path) %>
    </div>

    <% if @recent_care_events.any? %>
      <div class="mt-2 divide-y divide-vinci-border/80">
        <% @recent_care_events.each do |event| %>
          <%= render "timeline/care_event", event: event %>
        <% end %>
      </div>
    <% else %>
      <div class="mt-4 rounded-[20px] border border-dashed border-vinci-border bg-vinci-surface px-4 py-5">
        <p class="text-base font-medium text-vinci-ink">Nothing logged yet</p>
      </div>
    <% end %>
  </section>

  <div class="sticky bottom-4 z-10 -mx-1 border-t border-vinci-border/80 bg-vinci-surface/95 px-1 pt-4 backdrop-blur-sm">
    <div class="grid grid-cols-2 gap-3">
      <%= link_to "Feed", new_feed_path, class: "flex min-h-12 items-center justify-center rounded-full bg-vinci-accent px-4 py-4 text-base font-semibold text-vinci-surface transition hover:bg-vinci-ink focus:outline-none focus:ring-2 focus:ring-vinci-accent/20" %>
      <%= link_to "Diaper", new_diaper_path, class: "flex min-h-12 items-center justify-center rounded-full border border-vinci-border bg-vinci-base px-4 py-4 text-base font-semibold text-vinci-ink transition hover:border-vinci-accent hover:text-vinci-accent focus:outline-none focus:ring-2 focus:ring-vinci-accent/20" %>
    </div>
  </div>
</section>
