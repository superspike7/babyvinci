<% content_for :title, "Start sleep | BabyVinci" %>

<section class="space-y-6 pb-28">
  <header class="space-y-4 border-b border-vinci-border/80 pb-5">
    <div>
      <%= secondary_nav_link_to("Back to today", today_path) %>
    </div>

    <div class="flex items-start justify-between gap-4">
      <div class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-vinci-label">Shared log</p>
        <h1 class="text-3xl font-semibold tracking-tight text-vinci-ink">Start sleep</h1>
      </div>

      <span class="shrink-0 rounded-full bg-vinci-accent-tint px-3 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-vinci-accent">
        Now
      </span>
    </div>

    <p class="max-w-[19rem] text-base leading-7 text-vinci-text">Capture when sleep started in one save.</p>
  </header>

  <%= render "shared/primary_nav", current: nil %>

  <%= form_with model: @care_event, url: sleeps_path, class: "space-y-5", html: { novalidate: true } do |form| %>
    <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Required</p>

      <div class="mt-4 space-y-5">
        <div class="space-y-2">
          <%= form.label :started_at, "Time", class: "text-sm font-medium text-vinci-ink" %>
          <%= form.datetime_local_field :started_at, required: true, value: (@care_event.started_at || Time.zone.now.change(sec: 0)).strftime("%Y-%m-%dT%H:%M"), class: "w-full rounded-2xl border border-vinci-border bg-vinci-surface px-4 py-4 text-base text-vinci-ink outline-none transition focus:border-vinci-accent focus:ring-2 focus:ring-vinci-accent/10" %>
        </div>
      </div>
    </section>

    <% if @care_event.errors.any? %>
      <section class="rounded-[20px] border border-vinci-urgent/20 bg-red-50 px-4 py-3 text-sm text-vinci-urgent">
        <%= @care_event.errors.full_messages.to_sentence %>
      </section>
    <% end %>

    <div class="sticky bottom-0 z-10 -mx-4 border-t border-vinci-border/80 bg-vinci-surface/95 px-4 pt-4 pb-[calc(1rem+env(safe-area-inset-bottom))] backdrop-blur-sm">
      <%= form.submit "Start sleep", class: "w-full rounded-full bg-vinci-accent px-4 py-4 text-base font-semibold text-vinci-surface transition hover:bg-vinci-ink focus:outline-none focus:ring-2 focus:ring-vinci-accent/20" %>
    </div>
  <% end %>
</section>
