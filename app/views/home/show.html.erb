<% content_for :title, "Today | BabyVinci" %>

<section class="space-y-6">
  <header class="space-y-3 border-b border-vinci-border/80 pb-5">
    <div class="flex items-start justify-between gap-4">
      <div class="space-y-2">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-vinci-label">Shared log</p>
        <h1 class="text-3xl font-semibold tracking-tight text-vinci-ink">Today</h1>
      </div>

      <span class="shrink-0 rounded-full bg-vinci-accent-tint px-3 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-vinci-accent">
        <%= baby_age_label(current_baby) %>
      </span>
    </div>

    <p class="max-w-[18rem] text-base leading-7 text-vinci-text">
      <span class="font-medium text-vinci-ink"><%= current_baby.first_name %></span>
      is <%= baby_age_in_words(current_baby) %>.
    </p>
  </header>

  <%= render "shared/primary_nav", current: :today %>

  <section class="grid gap-4">
    <article class="rounded-[26px] border border-vinci-border bg-vinci-base p-5">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Last feed</p>
      <p class="mt-3 text-2xl font-semibold tracking-tight text-vinci-ink"><%= @last_feed ? latest_care_event_label(@last_feed) { "feed" } : "No feed yet" %></p>
      <% if @last_feed %>
        <p class="mt-2 text-sm leading-6 text-vinci-text"><%= care_event_detail(@last_feed) %></p>
      <% end %>
    </article>

    <article class="rounded-[26px] border border-vinci-border bg-vinci-base p-5">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Last diaper</p>
      <p class="mt-3 text-2xl font-semibold tracking-tight text-vinci-ink"><%= @last_diaper ? latest_care_event_label(@last_diaper) { "diaper" } : "No diaper yet" %></p>
      <% if @last_diaper %>
        <p class="mt-2 text-sm leading-6 text-vinci-text"><%= care_event_detail(@last_diaper) %></p>
      <% end %>
    </article>

    <% if @active_sleep %>
      <article class="rounded-[26px] border border-vinci-border bg-vinci-accent p-5" data-controller="sleep-timer" data-sleep-timer-started-at-value="<%= @active_sleep.started_at.to_i %>">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-surface/80">Sleep status</p>
          <span class="rounded-full bg-vinci-surface/20 px-3 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-vinci-surface">Now</span>
        </div>

        <div class="mt-4 flex items-center gap-3">
          <div class="flex size-12 items-center justify-center rounded-full bg-vinci-surface/15">
            <svg viewBox="0 0 24 24" fill="currentColor" class="size-6 text-vinci-surface">
              <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
            </svg>
          </div>
          <div>
            <p class="text-2xl font-semibold tracking-tight text-vinci-surface">Sleeping now</p>
            <p class="text-sm text-vinci-surface/80" data-sleep-timer-target="elapsed">Started <%= care_event_elapsed_label(@active_sleep.started_at) %></p>
          </div>
        </div>

        <%= button_to end_sleep_sleeps_path, method: :post, class: "mt-4 w-full rounded-full border border-vinci-surface/30 bg-vinci-surface/10 px-4 py-4 text-base font-semibold text-vinci-surface transition hover:bg-vinci-surface/20 focus:outline-none focus:ring-2 focus:ring-vinci-surface/20" do %>
          End sleep →
        <% end %>
      </article>
    <% else %>
      <article class="rounded-[26px] border border-vinci-border bg-vinci-base p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Last sleep</p>
        <p class="mt-3 text-2xl font-semibold tracking-tight text-vinci-ink"><%= @last_sleep ? sleep_duration_label(@last_sleep.duration_minutes) : "No sleep yet" %></p>
        <% if @last_sleep %>
          <p class="mt-2 text-sm leading-6 text-vinci-text"><%= sleep_detail_label(@last_sleep) %></p>
        <% end %>
      </article>
    <% end %>
  </section>

  <% reminder_presets = [[30, "30 min"], [60, "1 hour"], [120, "2 hours"], [180, "3 hours"]] %>

  <section class="rounded-[30px] border border-vinci-border/80 bg-vinci-accent-tint px-5 py-6 shadow-[0_22px_70px_rgba(17,63,72,0.08)]">
    <div class="flex items-center justify-between gap-3">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-vinci-label">Next feed reminder</p>
      <span class="rounded-full bg-vinci-surface/85 px-3.5 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-vinci-text">
        <%= @next_feed_reminder.persisted? ? next_feed_reminder_state_label(@next_feed_reminder) : "Ready" %>
      </span>
    </div>

    <% if @next_feed_reminder.persisted? && @next_feed_reminder.calendar_sync_failed_at.present? %>
      <div class="mt-3 rounded-[20px] border border-vinci-urgent/30 bg-vinci-urgent/10 px-4 py-3">
        <p class="text-sm text-vinci-urgent">Calendar sync failed. Your reminder is saved in BabyVinci.</p>
        <p class="mt-1 text-xs text-vinci-text">Tap edit to try again.</p>
      </div>
    <% end %>

    <% if @next_feed_reminder.persisted? %>
      <div class="relative mt-5">
        <div class="pointer-events-none absolute top-0 left-0 z-10 flex h-[76px] items-center pl-3.5">
          <%= button_to next_feed_reminder_path, method: :delete, form_class: "pointer-events-auto", class: "flex size-12 items-center justify-center rounded-full border border-vinci-border/60 bg-vinci-surface text-vinci-text shadow-[0_8px_22px_rgba(17,63,72,0.10)] transition hover:bg-vinci-base focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/15" do %>
            <span class="sr-only">Clear reminder</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" class="size-5" aria-hidden="true">
              <path d="M3 6h18" />
              <path d="M8 6V4h8v2" />
              <path d="M19 6l-1 14H6L5 6" />
              <path d="M10 11v6" />
              <path d="M14 11v6" />
            </svg>
          <% end %>
        </div>

        <details class="group" <%= "open" if @next_feed_reminder.errors.any? %>>
          <summary class="relative flex min-h-[76px] cursor-pointer list-none items-center justify-center rounded-full border border-vinci-border/70 bg-vinci-base px-16 shadow-[0_10px_28px_rgba(17,63,72,0.08)] transition marker:hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/15 [&::-webkit-details-marker]:hidden">
            <span class="sr-only">Edit reminder</span>

            <span class="flex flex-wrap items-end justify-center gap-x-1.5 gap-y-0.5 text-vinci-accent">
              <span class="text-[1.65rem] font-semibold leading-none tracking-[-0.06em] sm:text-[1.75rem]"><%= next_feed_reminder_label(@next_feed_reminder) %></span>
              <span class="pb-0.5 text-[0.8rem] font-semibold uppercase tracking-[0.08em] text-vinci-text"><%= next_feed_reminder_compact_status(@next_feed_reminder) %></span>
            </span>

            <span class="absolute top-1/2 right-3.5 flex size-12 -translate-y-1/2 items-center justify-center rounded-full bg-vinci-accent text-vinci-base shadow-[0_12px_28px_rgba(16,52,60,0.24)]" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" class="size-5">
                <path d="M12 20h9" />
                <path d="M16.5 3.5a2.1 2.1 0 1 1 3 3L7 19l-4 1 1-4 12.5-12.5Z" />
              </svg>
            </span>
          </summary>

          <div class="mt-4 space-y-4 rounded-[24px] border border-vinci-border/70 bg-vinci-surface/80 p-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-vinci-label">Quick presets</p>
              <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-4">
                <% reminder_presets.each do |minutes, label| %>
                  <%= button_to label, next_feed_reminder_path, method: :patch, params: { preset_minutes: minutes }, class: "inline-flex min-h-11 items-center justify-center rounded-full border border-vinci-border bg-vinci-base px-3 text-sm font-semibold text-vinci-accent transition hover:bg-vinci-surface focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/15" %>
                <% end %>
              </div>
            </div>

            <%= form_with model: @next_feed_reminder, url: next_feed_reminder_path, method: :patch, class: "space-y-3" do |form| %>
              <div>
                <%= form.label :target_at, "Exact time", class: "text-xs font-semibold uppercase tracking-[0.18em] text-vinci-label" %>
                <%= form.datetime_local_field :target_at, value: next_feed_reminder_input_value(@next_feed_reminder), class: "mt-2 block min-h-12 w-full rounded-[20px] border border-vinci-border bg-vinci-base px-4 py-3 text-base text-vinci-ink focus:border-vinci-accent/30 focus:outline-none focus:ring-2 focus:ring-vinci-accent/15" %>
                <% if @next_feed_reminder.errors[:target_at].any? %>
                  <p class="mt-2 text-sm text-vinci-urgent"><%= @next_feed_reminder.errors.full_messages_for(:target_at).first %></p>
                <% end %>
              </div>

              <%= form.submit "Update reminder", class: "inline-flex min-h-12 w-full items-center justify-center rounded-full bg-vinci-accent px-4 py-3 text-base font-semibold text-vinci-base transition hover:opacity-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/20" %>
            <% end %>
          </div>
        </details>
      </div>
    <% else %>
      <div class="mt-5 rounded-[28px] border border-vinci-border/70 bg-vinci-base p-5 shadow-[0_10px_28px_rgba(17,63,72,0.08)]">
        <p class="text-lg font-semibold tracking-tight text-vinci-accent">No reminder set</p>
        <p class="mt-2 text-sm leading-6 text-vinci-text">Pick a quick nudge or choose an exact time.</p>

        <div class="mt-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-vinci-label">Quick presets</p>
          <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-4">
            <% reminder_presets.each do |minutes, label| %>
              <%= button_to label, next_feed_reminder_path, method: :post, params: { preset_minutes: minutes }, class: "inline-flex min-h-11 items-center justify-center rounded-full border border-vinci-border bg-vinci-surface px-3 text-sm font-semibold text-vinci-accent transition hover:bg-vinci-base focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/15" %>
            <% end %>
          </div>
        </div>

        <%= form_with model: @next_feed_reminder, url: next_feed_reminder_path, method: :post, class: "mt-4 space-y-3" do |form| %>
          <div>
            <%= form.label :target_at, "Exact time", class: "text-xs font-semibold uppercase tracking-[0.18em] text-vinci-label" %>
            <%= form.datetime_local_field :target_at, value: next_feed_reminder_input_value(@next_feed_reminder), class: "mt-2 block min-h-12 w-full rounded-[20px] border border-vinci-border bg-vinci-surface px-4 py-3 text-base text-vinci-ink focus:border-vinci-accent/30 focus:outline-none focus:ring-2 focus:ring-vinci-accent/15" %>
            <% if @next_feed_reminder.errors[:target_at].any? %>
              <p class="mt-2 text-sm text-vinci-urgent"><%= @next_feed_reminder.errors.full_messages_for(:target_at).first %></p>
            <% end %>
          </div>

          <%= form.submit "Set reminder", class: "inline-flex min-h-12 w-full items-center justify-center rounded-full bg-vinci-accent px-4 py-3 text-base font-semibold text-vinci-base transition hover:opacity-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/20" %>
        <% end %>
      </div>
    <% end %>
  </section>

  <section class="rounded-[26px] border border-vinci-border/60 bg-vinci-base p-5 border-l-4 border-l-vinci-urgent/60">
    <details class="group">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-3 marker:hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/15 [&::-webkit-details-marker]:hidden">
        <div class="flex items-center gap-3">
          <div class="flex size-10 items-center justify-center rounded-full bg-vinci-urgent/10">
            <svg viewBox="0 0 24 24" fill="currentColor" class="size-5 text-vinci-urgent">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-vinci-label">Concerned?</p>
            <p class="text-sm text-vinci-text">Quick questions to guide next steps</p>
          </div>
        </div>
        <span class="flex size-10 items-center justify-center rounded-full text-vinci-text transition group-open:rotate-180" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="size-5">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </span>
      </summary>
      <div class="mt-4 space-y-3">
        <%= link_to concerns_path, class: "block rounded-[20px] border border-vinci-border bg-vinci-surface px-4 py-4 transition hover:border-vinci-urgent/30" do %>
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="text-base font-semibold text-vinci-ink">Check on something</p>
              <p class="text-sm text-vinci-text">Fever, breathing, vomiting, sleepiness, fewer diapers</p>
            </div>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="size-5 text-vinci-text">
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </div>
        <% end %>

        <div class="rounded-[20px] border border-dashed border-vinci-border bg-vinci-surface px-4 py-3">
          <p class="text-sm leading-6 text-vinci-text">
            <span class="font-medium text-vinci-ink">Trust your instincts.</span>
            When in doubt, call your pediatrician. These flows do not diagnose conditions.
          </p>
        </div>
      </div>
    </details>
  </section>

  <% if @guidance_notes.any? %>
    <section class="rounded-[26px] border border-vinci-border/60 bg-vinci-base p-5">
      <details class="group">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-3 marker:hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/15 [&::-webkit-details-marker]:hidden">
          <div class="flex items-center gap-3">
            <div class="flex size-10 items-center justify-center rounded-full bg-vinci-accent-tint/60">
              <svg viewBox="0 0 24 24" fill="currentColor" class="size-5 text-vinci-accent">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
              </svg>
            </div>
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-vinci-label">At this age</p>
          </div>
          <span class="flex size-10 items-center justify-center rounded-full text-vinci-text transition group-open:rotate-180" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="size-5">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </span>
        </summary>
        <div class="mt-4 space-y-3 pl-13">
          <% @guidance_notes.each do |note| %>
            <p class="text-base leading-6 text-vinci-ink"><%= note %></p>
          <% end %>
        </div>
      </details>
    </section>
  <% end %>

  <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5">
    <div class="flex items-center justify-between gap-4">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Recent activity</p>
      <%= secondary_nav_link_to("Open timeline", timeline_path) %>
    </div>

    <% if @recent_care_events.any? %>
      <div class="mt-2 divide-y divide-vinci-border/80">
        <% @recent_care_events.each do |event| %>
          <%= render "timeline/care_event", event: event %>
        <% end %>
      </div>
    <% else %>
      <div class="mt-4 rounded-[20px] border border-dashed border-vinci-border bg-vinci-surface px-4 py-5">
        <p class="text-base font-medium text-vinci-ink">Nothing logged yet</p>
      </div>
    <% end %>
  </section>

  <div class="h-28"></div>
</section>
  <%= render "shared/sticky_action_bar" %>
