<article class="flex items-start justify-between gap-4 py-4 first:pt-4 last:pb-0">
  <div class="min-w-0 space-y-1">
    <div class="flex items-center gap-3">
      <p class="text-base font-semibold text-vinci-ink"><%= care_event_name(event) %></p>
      <p class="text-sm text-vinci-text"><%= care_event_time(event) %></p>
    </div>

    <p class="text-sm leading-6 text-vinci-text"><%= care_event_detail(event) %></p>
    <p class="text-sm text-vinci-text"><%= care_event_author(event) %></p>
  </div>

  <div class="shrink-0 text-right">
    <p class="text-sm font-medium text-vinci-label"><%= care_event_elapsed_label(event.started_at) %></p>
    <%= link_to "Edit", edit_care_event_path(event, return_to: request.fullpath), class: "mt-2 inline-flex min-h-11 items-center text-sm font-semibold text-vinci-accent underline decoration-vinci-accent/60 decoration-2 underline-offset-4 transition-colors hover:text-vinci-ink hover:decoration-vinci-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-vinci-accent/25" %>
  </div>
</article>
