<div data-controller="drawer" class="h-full w-full flex flex-col relative overflow-hidden">
  
  <!-- Top 50%: Timeline -->
  <div class="flex-1 overflow-y-auto px-4 py-8 flex flex-col gap-4 no-scrollbar">
    <!-- Super minimal timeline, just showing times to give max space to buttons -->
    <div class="flex justify-between items-center py-2 border-b border-neutral-800">
      <div class="flex items-center gap-3">
        <span class="text-2xl opacity-80">🍼</span>
        <span class="text-white font-medium">Fed 90ml</span>
      </div>
      <span class="text-neutral-500 text-sm">2h ago</span>
    </div>
    <div class="flex justify-between items-center py-2 border-b border-neutral-800">
      <div class="flex items-center gap-3">
        <span class="text-2xl opacity-80">💤</span>
        <span class="text-white font-medium">Woke up</span>
      </div>
      <span class="text-neutral-500 text-sm">3.5h ago</span>
    </div>
    <div class="flex justify-between items-center py-2 border-b border-neutral-800">
      <div class="flex items-center gap-3">
        <span class="text-2xl opacity-80">🧻</span>
        <span class="text-white font-medium">Wet Diaper</span>
      </div>
      <span class="text-neutral-500 text-sm">5h ago</span>
    </div>
  </div>

  <!-- Bottom 50%: Action Rows -->
  <div class="h-[50%] flex flex-col pb-8 pt-2 px-2 gap-2 bg-neutral-950 shadow-[0_-20px_40px_rgba(0,0,0,0.5)]">
    
    <!-- Row 1: Feed (Top of the bottom section) -->
    <button data-action="click->drawer#open" data-type="feed" class="flex-1 rounded-2xl bg-pink-950/30 border border-pink-900/50 flex items-center px-6 active:bg-pink-900/50 transition-colors group">
      <div class="w-16 h-16 rounded-full bg-pink-900/40 flex items-center justify-center text-3xl mr-6">🍼</div>
      <div class="flex-1 text-left">
        <h3 class="text-pink-300 text-2xl font-bold tracking-wide">FEED</h3>
        <p class="text-pink-800 text-sm font-medium">Last: 2h ago</p>
      </div>
      <div class="text-pink-800 text-2xl">›</div>
    </button>
    
    <!-- Row 2: Diaper (Middle) -->
    <button data-action="click->drawer#open" data-type="diaper" class="flex-1 rounded-2xl bg-yellow-950/30 border border-yellow-900/50 flex items-center px-6 active:bg-yellow-900/50 transition-colors group">
      <div class="w-16 h-16 rounded-full bg-yellow-900/40 flex items-center justify-center text-3xl mr-6">🧻</div>
      <div class="flex-1 text-left">
        <h3 class="text-yellow-500 text-2xl font-bold tracking-wide">DIAPER</h3>
        <p class="text-yellow-800 text-sm font-medium">Last: 5h ago</p>
      </div>
      <div class="text-yellow-800 text-2xl">›</div>
    </button>
    
    <!-- Row 3: Sleep (Bottom absolute edge) -->
    <button data-action="click->drawer#open" data-type="sleep" class="flex-1 rounded-2xl bg-blue-950/30 border border-blue-900/50 flex items-center px-6 active:bg-blue-900/50 transition-colors group">
      <div class="w-16 h-16 rounded-full bg-blue-900/40 flex items-center justify-center text-3xl mr-6">💤</div>
      <div class="flex-1 text-left">
        <h3 class="text-blue-300 text-2xl font-bold tracking-wide">SLEEP</h3>
        <p class="text-blue-800 text-sm font-medium">Last: 3.5h ago</p>
      </div>
      <div class="text-blue-800 text-2xl">›</div>
    </button>
    
  </div>

  <!-- OVERLAY -->
  <div data-drawer-target="overlay" data-action="click->drawer#close" class="absolute inset-0 bg-black/60 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300"></div>

  <!-- FEED DRAWER (Reused from Concept 1) -->
  <div data-drawer-target="feedDrawer" class="absolute bottom-0 left-0 w-full h-[60%] bg-neutral-900 rounded-t-3xl border-t border-neutral-800 z-50 transform translate-y-full transition-transform duration-300 shadow-2xl flex flex-col">
    <div class="w-full flex justify-center pt-3 pb-5" data-action="click->drawer#close">
      <div class="w-12 h-1.5 bg-neutral-700 rounded-full"></div>
    </div>
    <div class="px-6 flex-1 flex flex-col gap-4 pb-8">
      <button data-action="click->drawer#logAndClose" class="w-full py-6 rounded-2xl bg-pink-900/30 border border-pink-900/50 text-pink-300 text-2xl font-bold relative overflow-hidden active:bg-pink-900/60">
        Left Breast
      </button>
      <button data-action="click->drawer#logAndClose" class="w-full py-6 rounded-2xl bg-pink-900/30 border border-pink-900/50 text-pink-300 text-2xl font-bold relative overflow-hidden active:bg-pink-900/60">
        Right Breast
      </button>
      <div class="grid grid-cols-2 gap-4 mt-2">
        <button data-action="click->drawer#logAndClose" class="w-full py-5 rounded-2xl bg-neutral-800 border border-neutral-700 text-neutral-300 text-xl font-bold active:bg-neutral-700">
          Bottle
        </button>
        <button data-action="click->drawer#logAndClose" class="w-full py-5 rounded-2xl bg-neutral-800 border border-neutral-700 text-neutral-300 text-xl font-bold active:bg-neutral-700">
          Pump
        </button>
      </div>
    </div>
  </div>

  <!-- DIAPER DRAWER -->
  <div data-drawer-target="diaperDrawer" class="absolute bottom-0 left-0 w-full h-[50%] bg-neutral-900 rounded-t-3xl border-t border-neutral-800 z-50 transform translate-y-full transition-transform duration-300 flex flex-col">
    <div class="w-full flex justify-center pt-3 pb-5" data-action="click->drawer#close">
      <div class="w-12 h-1.5 bg-neutral-700 rounded-full"></div>
    </div>
    <div class="px-6 flex-1 flex flex-col gap-4 pb-8">
      <button data-action="click->drawer#logAndClose" class="w-full py-6 rounded-2xl bg-yellow-900/30 border border-yellow-900/50 text-yellow-500 text-2xl font-bold active:bg-yellow-900/60">
        Wet
      </button>
      <button data-action="click->drawer#logAndClose" class="w-full py-6 rounded-2xl bg-[#5C4033]/40 border border-[#5C4033]/60 text-amber-600 text-2xl font-bold active:bg-[#5C4033]/60">
        Dirty
      </button>
    </div>
  </div>

  <!-- SLEEP DRAWER -->
  <div data-drawer-target="sleepDrawer" class="absolute bottom-0 left-0 w-full h-[40%] bg-neutral-900 rounded-t-3xl border-t border-neutral-800 z-50 transform translate-y-full transition-transform duration-300 flex flex-col">
    <div class="w-full flex justify-center pt-3 pb-5" data-action="click->drawer#close">
      <div class="w-12 h-1.5 bg-neutral-700 rounded-full"></div>
    </div>
    <div class="px-6 flex-1 flex flex-col justify-center gap-4 pb-8">
      <button data-action="click->drawer#logAndClose" class="w-full py-8 rounded-3xl bg-blue-900/30 border border-blue-900/50 text-blue-300 text-3xl font-bold active:bg-blue-900/60">
        Start Sleep
      </button>
    </div>
  </div>
</div>