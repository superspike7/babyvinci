<section class="space-y-6">
  <header class="space-y-3">
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-vinci-label">BabyVinci</p>
    <div class="space-y-2">
      <h1 class="text-3xl font-semibold tracking-tight text-vinci-ink">Join <%= @invite.baby.first_name %>&#39;s shared log</h1>
      <p class="text-base leading-7 text-vinci-text">This invite is for <span class="font-medium text-vinci-ink"><%= @invite.email %></span>. Use that same email to join the baby workspace.</p>
    </div>
  </header>

  <% if @error_message.present? %>
    <section class="rounded-[20px] border border-vinci-urgent/20 bg-red-50 px-4 py-3 text-sm text-vinci-urgent">
      <%= @error_message %>
    </section>
  <% end %>

  <% if authenticated? %>
    <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5 shadow-[0_22px_70px_rgba(17,63,72,0.10)]">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label">Signed in as</p>
      <p class="mt-3 text-base text-vinci-ink"><%= current_user.email %></p>
      <%= button_to "Join shared log", invite_acceptance_path(@invite.token), class: "mt-5 w-full rounded-full bg-vinci-accent px-4 py-4 text-base font-semibold text-vinci-surface" %>
    </section>
  <% else %>
    <%= form_with url: invite_acceptance_path(@invite.token), scope: :acceptance, class: "space-y-5" do |form| %>
      <section class="rounded-[26px] border border-vinci-border bg-vinci-base p-5 shadow-[0_22px_70px_rgba(17,63,72,0.10)]">
        <div class="space-y-4">
          <div class="space-y-2">
            <%= form.label :name, class: "text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label" %>
            <%= form.text_field :name, required: true, autofocus: true, autocomplete: "name", value: @acceptance_user.name, class: "w-full rounded-2xl border border-vinci-border bg-vinci-surface px-4 py-4 text-base text-vinci-ink outline-none" %>
          </div>

          <div class="space-y-2">
            <%= form.label :email, class: "text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label" %>
            <%= form.email_field :email, required: true, autocomplete: "email", value: @acceptance_user.email, class: "w-full rounded-2xl border border-vinci-border bg-vinci-surface px-4 py-4 text-base text-vinci-ink outline-none" %>
          </div>

          <div class="space-y-2">
            <%= form.label :password, class: "text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label" %>
            <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72, class: "w-full rounded-2xl border border-vinci-border bg-vinci-surface px-4 py-4 text-base text-vinci-ink outline-none" %>
          </div>

          <div class="space-y-2">
            <%= form.label :password_confirmation, "Confirm password", class: "text-sm font-semibold uppercase tracking-[0.18em] text-vinci-label" %>
            <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72, class: "w-full rounded-2xl border border-vinci-border bg-vinci-surface px-4 py-4 text-base text-vinci-ink outline-none" %>
          </div>
        </div>
      </section>

      <% if @acceptance_user.errors.any? %>
        <section class="rounded-[20px] border border-vinci-urgent/20 bg-red-50 px-4 py-3 text-sm text-vinci-urgent">
          <%= @acceptance_user.errors.full_messages.to_sentence %>
        </section>
      <% end %>

      <%= form.submit "Create account and join", class: "w-full rounded-full bg-vinci-accent px-4 py-4 text-base font-semibold text-vinci-surface" %>
    <% end %>

    <p class="text-center text-sm text-vinci-text">
      Already have an account? Sign in first, then reopen this invite link.
    </p>
  <% end %>
</section>
